# Copy this file to ".env" and adjust as needed.

# Database (SQLite for local dev; use a Neon PostgreSQL URL in production)
DATABASE_URL="file:./dev.db"

# Where the Python FastAPI ML service is running
ML_API_URL="http://127.0.0.1:8000"

# Secret used to sign JWT session cookies — CHANGE THIS to a long random string
AUTH_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"
